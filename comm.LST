 120          /*----------------------------
 121          UART 中断服务程序
 122          -----------------------------*/
 123          void Uart() interrupt 4 using 1
 124          {
 125   1          if (RI)
 126   1          {
 127   2              RI = 0;                 //清除RI位
 128   2              P0 = SBUF;              //P0显示串口数据
 129   2              P22 = RB8;              //P2.2显示校验位
 130   2          }
 131   1          if (TI)
 132   1          {
 133   2              TI = 0;                 //清除TI位
 134   2              busy = 0;               //清忙标志
 135   2          }
 136   1      }
 137          
 138          /*----------------------------
 139          发送串口数据
 140          ----------------------------*/
 141          void SendData(BYTE dat)
 142          {
 143   1          while (busy);               //等待前面的数据发送完成
 144   1          ACC = dat;                  //获取校验位P (PSW.0)
 145   1          if (P)                      //根据P来设置校验位
 146   1          {
 147   2      #if (PARITYBIT == ODD_PARITY)
                      TB8 = 0;                //设置校验位为0
              #elif (PARITYBIT == EVEN_PARITY)
 150   2              TB8 = 1;                //设置校验位为1
 151   2      #endif
 152   2          }
 153   1          else
 154   1          {
 155   2      #if (PARITYBIT == ODD_PARITY)
                      TB8 = 1;                //设置校验位为1
              #elif (PARITYBIT == EVEN_PARITY)
 158   2              TB8 = 0;                //设置校验位为0
 159   2      #endif
 160   2          }
 161   1          busy = 1;
 162   1          SBUF = ACC;                 //写数据到UART数据寄存器
 163   1      }
 164          
 165          /*----------------------------
 166          发送字符串
 167          ----------------------------*/
 168          void SendString(char *s)
 169          {
 170   1          while (*s)                  //检测字符串结束标志
 171   1          {
 172   2              SendData(*s++);         //发送当前字符
 173   2          }
 174   1      }
