 255          void CMP_INT(void) interrupt 21
 256          {
 257   1        CMPCR1 &= ~0X40; // ашШэМўЧхГ§жаЖЯБъжОЮЛ
 258   1        if(Step<5)  Step++;
 259   1        else    Step = 0;
 260   1        StepXL();
 261   1        TimeOut = 10; //10msГЌЪБ
 262   1      }
