 271          u8 StartMotor(void)
 272          {
 273   1        u16 timer,i;
 274   1        DISABLE_CMP_INT;  // НћжЙБШНЯЦїжаЖЯ
 275   1        PWM_Value = 30;   // ГѕЪМеМПеБШ=16/256=6%
 276   1        Step = 0;
 277   1        StepXL();     // ГѕЪМЮЛжУ
 278   1        Delay_n_ms(5);//delay_ms(5);
 279   1        timer = 300;
 280   1      
 281   1        while(1)
 282   1        {
 283   2          for(i=0; i<timer; i++)  delay_us(50);  // ЕквЛДЮЪЧ15КСУыЃЌМгЩЯЩЯУцЕФ5КСУзбгЪБЃЌзмМЦДѓдМ20КСУы
 284   2          timer -= timer /15 + 1;
 285   2          if(timer < 25)  {
 286   3            CMPCR1 &= ~0X40;  // ашШэМўЧхГ§жаЖЯБъжОЮЛ
 287   3            B_RUN = 1;      // ТэДядЫааБъжОЮЛ
 288   3            PWM_Value = 0;    // ЦєЖЏЭъГЩЁЃЭЃзЊЃЌЕШДЎПкЕФPWW_SETжЕ
 289   3            TimeOut = 10;   // 10КСУзГЌЪБ
 290   3            ENABLE_CMP_INT;   // ДђПЊБШНЯЦїжаЖЯ
 291   3            return(1);
 292   3          }
 293   2          if( Step < 5) Step++;
 294   2          else      Step = 0;
 295   2          StepXL();
 296   2          // SendString("Start Motor!\r\n");
 297   2        }
 298   1      }
