 264          void CMP_Init(void)
 265          {
 266   1        CMPCR1 = 0X8C;  // 1000 1100 ДђПЊБШНЯЦїЃЌP5.4зїЮЊБШНЯЦїЕФЗДЯрЪфШыЖЫЃЌADCв§НХзїЮЊе§ЪфШыЖЫ 
 267   1        CMPCR2 = 60;  // 60ИіЪБжгТЫВЈ
 268   1        P5n_pure_input(0x10);
 269   1      }
